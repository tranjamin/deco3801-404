{
  "manifest_version": 3,
  "name": "TLS Checker",
  "version": "1.0",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "tabs", "debugger"],
  "host_permissions": [
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "tls_retrieval_engine.js",
    "type": "module"
  }
  
}